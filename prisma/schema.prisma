generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id                                       Int                  @id(map: "clients_pkey") @default(autoincrement()) @map("id")
  business                                 String               @unique(map: "clients_name_unique_idx") @map("name")
  websiteUrl                               String?              @unique @map("website_url")
  isActiveOnAiAuthorityExchange            Boolean              @default(false) @map("is_active_on_ai_authority_exchange")
  aiAuthorityExchangeJoinedAt              DateTime?            @map("ai_authority_exchange_joined_at") @db.Timestamp(6)
  aiAuthorityExchangeRetiredAt             DateTime?            @map("ai_authority_exchange_retired_at") @db.Timestamp(6)
  aiAuthorityExchangeRetiredInRoundBatchId Int?                 @map("ai_authority_exchange_retired_in_round_batch_id")
  google_drive_folder_url                  String?
  writer_411_document_url                  String?
  discovery_packet_document_url            String?
  client_status                            client_status        @default(active)
  created_at                               DateTime             @default(now()) @db.Date
  updated_at                               DateTime             @default(now()) @db.Date
  subcategory                              String?              @db.VarChar
  description                              String?
  writing_topics                           String[]
  target_audience                          String?
  business_category_id                     Int?
  domain_rating                            Int?
  related_category_ids                     Int[]
  related_categories_reasoning             String?
  clientType                               BusinessRoleType?    @default(partner) @map("role")
  guestMatches                             Match[]              @relation("GuestBusiness")
  hostedMatches                            Match[]              @relation("HostBusiness")
  aiAuthorityExchangeRetiredInRoundBatch   RoundBatch?          @relation("RetiredBusinesses", fields: [aiAuthorityExchangeRetiredInRoundBatchId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  incomingRoundAssignments                 RoundAssignment[]    @relation("RoundAssignmentGuestBusiness")
  outgoingRoundAssignments                 RoundAssignment[]    @relation("RoundAssignmentHostBusiness")
  business_categories                      business_categories? @relation(fields: [business_category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "business_category_id")
  client_details                           client_details?
  publications                             publications[]

  @@index([aiAuthorityExchangeRetiredInRoundBatchId], map: "idx_businesses_retired_round_batch_id")
  @@index([related_category_ids], map: "idx_clients_related_categories", type: Gin)
  @@index([writing_topics], map: "idx_clients_writing_topics", type: Gin)
  @@map("businesses")
}

model Match {
  id                          Int          @id(map: "matches_pkey") @default(autoincrement()) @map("id")
  hostId                      Int          @map("publisher_id")
  guestId                     Int          @map("guest_id")
  roundBatchId                Int?         @map("round_batch_id")
  status                      MatchStatus? @default(Not_Started) @map("status")
  interview_sent              Boolean?     @default(false)
  interview_published         Boolean?     @default(false)
  partner_interview_received  Boolean?     @default(false)
  partner_interview_published Boolean?     @default(false)
  notes                       String?
  created_at                  DateTime?    @default(now()) @db.Timestamp(6)
  guest                       Business     @relation("GuestBusiness", fields: [guestId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "matches_matched_id_fkey")
  host                        Business     @relation("HostBusiness", fields: [hostId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "matches_subject_id_fkey")
  roundBatch                  RoundBatch?  @relation(fields: [roundBatchId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([hostId, guestId], map: "unique_match_pair")
  @@index([roundBatchId], map: "idx_matches_round_batch_id")
  @@map("ai_authority_exchange_matches")
}

model RoundBatch {
  id                Int               @id @default(autoincrement())
  sequenceNumber    Int               @unique @map("sequence_number")
  status            RoundBatchStatus  @default(draft)
  appliedAt         DateTime?         @map("applied_at") @db.Timestamp(6)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamp(6)
  assignments       RoundAssignment[]
  matches           Match[]
  retiredBusinesses Business[]        @relation("RetiredBusinesses")

  @@map("ai_authority_exchange_round_batches")
}

model RoundAssignment {
  id              Int                   @id @default(autoincrement())
  roundBatchId    Int                   @map("round_batch_id")
  hostBusinessId  Int                   @map("host_business_id")
  guestBusinessId Int                   @map("guest_business_id")
  source          RoundAssignmentSource @default(auto)
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamp(6)
  guestBusiness   Business              @relation("RoundAssignmentGuestBusiness", fields: [guestBusinessId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  hostBusiness    Business              @relation("RoundAssignmentHostBusiness", fields: [hostBusinessId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  roundBatch      RoundBatch            @relation(fields: [roundBatchId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([roundBatchId, hostBusinessId, guestBusinessId], map: "unique_round_assignment_pair")
  @@index([roundBatchId], map: "idx_round_assignments_round_batch_id")
  @@map("ai_authority_exchange_round_assignments")
}

model business_categories {
  id               Int               @id
  name             String?
  sector_id        Int?
  economic_sectors economic_sectors? @relation(fields: [sector_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  businesses       Business[]
}

model client_details {
  id                            Int            @id @default(autoincrement())
  business_id                   Int            @unique
  status                        client_status? @default(active)
  google_drive_folder_url       String?
  writer_411_document_url       String?
  discovery_packet_document_url String?
  internal_notes                String?
  updated_at                    DateTime?      @default(now()) @db.Timestamp(6)
  businesses                    Business       @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model economic_sectors {
  id                  Int                   @id @default(autoincrement())
  name                String                @db.VarChar(50)
  description         String?
  business_categories business_categories[]
}

model publications {
  id                   Int       @id @default(autoincrement())
  name                 String?
  target_keyword       String?
  core_offer           String?
  template_url         String?
  special_instructions String?
  general_notes        String?
  client_id            Int
  user_id              Int
  page_type            page_type
  businesses           Business  @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "client_id")
  users                users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_id")
}

model users {
  id                   Int            @id @default(autoincrement())
  first_name           String?
  last_name            String?
  full_name            String?
  email                String?        @unique
  google_chat_space_id String?
  authUser             User?          @relation("LegacyUserAuthLink")
  publications         publications[]
}

model User {
  id            String    @id @default(cuid())
  legacyUserId  Int       @unique @map("legacy_user_id")
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  accounts      Account[]
  legacyUser    users     @relation("LegacyUserAuthLink", fields: [legacyUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sessions      Session[]

  @@map("auth_users")
}

model Account {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "auth_accounts_user_id_idx")
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "auth_sessions_user_id_idx")
  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

enum BusinessRoleType {
  client
  partner

  @@map("business_role_type")
}

enum MatchStatus {
  Not_Started     @map("Not Started")
  In_Progress     @map("In Progress")
  Done
  Leaving
  Partner_Leaving @map("Partner Leaving")

  @@map("match_status")
}

enum client_status {
  active
  inactive
}

enum page_type {
  Location
  Service
  Industry
  Use_Case           @map("Use Case")
  Product_Collection @map("Product Collection")
  Comparison_Blog    @map("Comparison Blog")
  Blog_Guide         @map("Blog/Guide")
  Metrics_Data       @map("Metrics/Data")
}

enum publication_direction {
  subject_publishes_match
  match_publishes_subject
}

enum RoundBatchStatus {
  draft
  applied
}

enum RoundAssignmentSource {
  auto
  manual
}
